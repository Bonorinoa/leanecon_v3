# LeanEcon v3 hosted runtime example
#
# Intended deployment profile:
# - Planner: Mistral structured chat completions
# - Formalizer: Leanstral via Mistral AI
# - Prover: Leanstral via Mistral AI
# - No local model serving required
#
# Usage:
#   cp .env.example .env
#   fill in your real secrets

LEANECON_ENV=local

# API
API_HOST=0.0.0.0
API_PORT=8000
PORT=8000
CORS_ORIGINS=*

# Lean / runtime
LEAN_TIMEOUT=60
REPL_ENABLED=true
FORMALIZER_REPL_VALIDATION_ENABLED=true
LEANECON_FORMALIZER_TIMEOUT=120

# Job / proving budgets
MAX_PROVE_STEPS=32
MAX_PROVE_TIMEOUT=300
MAX_TOTAL_TOOL_CALLS=40
MAX_SEARCH_TOOL_CALLS=12
JOB_TTL_SECONDS=3600
JOB_MAX_CONCURRENT=2

# Planner: Mistral Large 3
LEANECON_PLANNER_BACKEND=mistral-structured
LEANECON_PLANNER_PROVIDER=mistral
LEANECON_PLANNER_MODEL=mistral-large-2512
LEANECON_PLANNER_TIMEOUT=360
LEANECON_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Shared Mistral credentials
MISTRAL_API_KEY=replace-with-your-mistral-api-key
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Formalizer: Leanstral on Mistral
LEANECON_FORMALIZER_BACKEND=leanstral
LEANECON_FORMALIZER_MODEL=labs-leanstral-2603

# Prover: Leanstral on Mistral
LEANECON_PROVER_BACKEND=leanstral
LEANECON_PROVER_MODEL=labs-leanstral-2603
LEANECON_PROVER_PROVIDER=mistral

# Optional Hugging Face token
# Leave blank unless you intentionally switch a stage to a Hugging Face backend.
HF_TOKEN=

# Observability / benchmark settings
LEANECON_COST_TRACKING_ENABLED=true
LEANECON_BENCHMARK_REQUIRE_PRICING=true
LEANECON_BENCHMARK_MAX_RECURSION_DEPTH=1
LEANECON_LIVE_MODEL_TESTS=true

# Pricing overrides
# Planner pricing uses Mistral Large 3 reference rates. Leanstral remains a
# zero-cost sentinel here unless you want to track a custom internal rate.
LEANECON_PRICE_OVERRIDES_JSON='{"mistral":{"mistral-large-2512":{"input":0.5,"output":1.5},"labs-leanstral-2603":{"input":0.0,"output":0.0}}}'

# Notes
# - This template assumes no model is hosted fully locally.
# - The benchmark-default planner path is now Mistral, not Ollama.
# - With `LEANECON_LIVE_MODEL_TESTS=true`, Ollama planner readiness uses a real
#   hosted chat probe if you explicitly switch back to `ollama-cloud`.
# - Keep planner/formalizer/prover on hosted providers; this repo no longer
#   assumes any model will be served locally on the benchmark path.
