# Lean Econ v3 environment example
#
# Usage:
#   cp .env.example .env
#   edit .env with your real keys and model choices
#
# Minimum setup for hosted LLM runs:
# - Set `MISTRAL_API_KEY` for Leanstral-backed formalization.
# - Set `HF_TOKEN` for Hugging Face planner/prover calls.


# API
API_HOST=0.0.0.0
API_PORT=8000
PORT=8000
CORS_ORIGINS=*


# Lean / runtime
LEAN_TIMEOUT=60
REPL_ENABLED=true
FORMALIZER_REPL_VALIDATION_ENABLED=true
LEANECON_FORMALIZER_TIMEOUT=120


# Job / proving budgets
MAX_PROVE_STEPS=32
MAX_PROVE_TIMEOUT=300
MAX_TOTAL_TOOL_CALLS=40
MAX_SEARCH_TOOL_CALLS=12
JOB_TTL_SECONDS=3600
JOB_MAX_CONCURRENT=2


# Planner
# Requires Hugging Face credentials for hosted inference.
LEANECON_PLANNER_BACKEND=minimax-m2.7
LEANECON_PLANNER_MODEL=MiniMaxAI/MiniMax-M2.7
LEANECON_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2


# Formalizer
# `leanstral` is routed through Mistral AI using labs-leanstral-2603.
LEANECON_FORMALIZER_BACKEND=leanstral
LEANECON_FORMALIZER_MODEL=labs-leanstral-2603
MISTRAL_API_KEY=replace-with-your-mistral-api-key
MISTRAL_BASE_URL=https://api.mistral.ai/v1


# Prover
# Current prover model is served through Hugging Face in this repo.
LEANECON_PROVER_MODEL=hf:Goedel-LM/Goedel-Prover-V2-32B
HF_TOKEN=replace-with-your-huggingface-token


# Notes
# - Leave `PORT` aligned with `API_PORT` for local runs unless your host overrides it.
# - If you are only doing local smoke tests without hosted models, you can leave
#   the API keys blank, but live Planner/Formalizer/Prover calls will fail.
