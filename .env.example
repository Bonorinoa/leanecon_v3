# Lean Econ v3 environment example
#
# Usage:
#   cp .env.example .env
#   edit .env with your real keys and model choices
#
# Minimum setup for hosted LLM runs:
# - Set `MISTRAL_API_KEY` for Leanstral-backed formalization.
# - Set `HF_TOKEN` for Hugging Face planner calls or any routed HF inference use.

LEANECON_ENV=local

# API
API_HOST=0.0.0.0
API_PORT=8000
PORT=8000
CORS_ORIGINS=*


# Lean / runtime
LEAN_TIMEOUT=60
REPL_ENABLED=true
FORMALIZER_REPL_VALIDATION_ENABLED=true
LEANECON_FORMALIZER_TIMEOUT=120


# Job / proving budgets
MAX_PROVE_STEPS=32
MAX_PROVE_TIMEOUT=300
MAX_TOTAL_TOOL_CALLS=40
MAX_SEARCH_TOOL_CALLS=12
JOB_TTL_SECONDS=3600
JOB_MAX_CONCURRENT=2

# Planner
# Uses a signed-in local Ollama daemon to route the planner to Ollama Cloud.
LEANECON_PLANNER_BACKEND=ollama-cloud
LEANECON_PLANNER_MODEL=gemma4:31b-cloud
LEANECON_PLANNER_PROVIDER=ollama
LEANECON_OLLAMA_HOST=http://127.0.0.1:11434
LEANECON_PLANNER_TIMEOUT=120
LEANECON_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

## Ollama
OLLAMA_API_KEY=your_api_key

# Formalizer
# `leanstral` is routed through Mistral AI using labs-leanstral-2603.
LEANECON_FORMALIZER_BACKEND=leanstral
LEANECON_FORMALIZER_MODEL=labs-leanstral-2603
MISTRAL_API_KEY=replace-with-your-mistral-api-key
MISTRAL_BASE_URL=https://api.mistral.ai/v1


# Prover
# Default to Leanstral for live runs. Goedel via Hugging Face now requires a
# separately deployed endpoint or another provider path before it is benchmark-ready.
LEANECON_PROVER_BACKEND=leanstral
LEANECON_PROVER_MODEL=hf:Goedel-LM/Goedel-Prover-V2-32B
LEANECON_PROVER_PROVIDER=auto
HF_TOKEN=replace-with-your-huggingface-token


# Observability / benchmark determinism
LEANECON_COST_TRACKING_ENABLED=true
LEANECON_BENCHMARK_REQUIRE_PRICING=true
LEANECON_BENCHMARK_MAX_RECURSION_DEPTH=1
LEANECON_LIVE_MODEL_TESTS=false

# Pricing
LEANECON_PRICE_OVERRIDES_JSON='{"huggingface":{"Goedel-LM/Goedel-Prover-V2-32B":{"input":0.0004,"output":0.0004}},"mistral":{"labs-leanstral-2603":{"input":0.0,"output":0.0}},"ollama":{"gemma4:31b-cloud":{"input":0.0,"output":0.0}}}'

# Notes
# - Leave `PORT` aligned with `API_PORT` for local runs unless your host overrides it.
# - If you are only doing local smoke tests without hosted models, you can leave
#   the API keys blank, but live Planner/Formalizer/Prover calls will fail.
# - `LEANECON_PLANNER_MODEL=gemma4:31b-cloud` expects `ollama pull
#   gemma4:31b-cloud` to have succeeded on the local daemon.
# - Raise `LEANECON_PLANNER_TIMEOUT` when you want a capability sweep rather
#   than a latency-constrained benchmark.
# - Raise `LEANECON_BENCHMARK_MAX_RECURSION_DEPTH` when you want to test prover
#   headroom beyond the strict stabilization cap.
# - If you need benchmark readiness without `--allow-unready`, add an Ollama
#   planner price override under the `ollama` provider key.
